model IntegrationConnection {
  id             BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  companyId      BigInt          @map("company_id") @db.UnsignedBigInt
  name           String          @db.VarChar(160)
  connectionType ConnectionType  @map("connection_type")
  host           String?         @db.VarChar(255)
  port           Int?            @db.SmallInt
  databaseName   String?         @map("database_name") @db.VarChar(120)
  username       String?         @db.VarChar(120)
  passwordEnc    String?         @map("password_enc") @db.Text
  apiBaseUrl     String?         @map("api_base_url") @db.VarChar(500)
  apiKeyEnc      String?         @map("api_key_enc") @db.Text
  extraConfig    String?         @map("extra_config") @db.LongText
  syncSchedule   SyncSchedule?   @default(manual) @map("sync_schedule")
  lastSyncAt     DateTime?       @map("last_sync_at") @db.Timestamp(0)
  lastSyncStatus SyncStatus?     @default(never) @map("last_sync_status")
  lastSyncLog    String?         @map("last_sync_log") @db.Text
  isActive       Boolean         @default(true) @map("is_active")
  createdBy      BigInt?         @map("created_by") @db.UnsignedBigInt
  createdAt      DateTime?       @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime?       @map("updated_at") @db.Timestamp(0)
  importMappings ImportMapping[]
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator        User?           @relation(fields: [createdBy], references: [id])

  @@index([companyId, connectionType, isActive], map: "idx_conn_company_type")
  @@index([createdBy], map: "integration_connections_created_by_fkey")
  @@map("integration_connections")
}

model ImportMapping {
  id            BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  companyId     BigInt                 @map("company_id") @db.UnsignedBigInt
  connectionId  BigInt?                @map("connection_id") @db.UnsignedBigInt
  name          String                 @db.VarChar(160)
  sourceSystem  ImportSourceSystem     @map("source_system")
  importType    ImportType             @map("import_type")
  mappingConfig String                 @map("mapping_config") @db.LongText
  skipErrors    Boolean?               @default(false) @map("skip_errors")
  isDefault     Boolean?               @default(false) @map("is_default")
  isActive      Boolean?               @default(true) @map("is_active")
  lastUsedAt    DateTime?              @map("last_used_at") @db.Timestamp(0)
  createdBy     BigInt?                @map("created_by") @db.UnsignedBigInt
  createdAt     DateTime?              @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime?              @map("updated_at") @db.Timestamp(0)
  actualImports ActualImport[]
  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connection    IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  creator       User?                  @relation(fields: [createdBy], references: [id])

  @@index([companyId, sourceSystem, importType], map: "idx_mapping_company_source")
  @@index([connectionId], map: "idx_mapping_connection")
  @@index([createdBy], map: "import_mappings_created_by_fkey")
  @@map("import_mappings")
}

