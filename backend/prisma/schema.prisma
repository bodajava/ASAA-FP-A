generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model Plan {
  id            BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  name          String         @db.VarChar(120)
  monthlyPrice  Decimal        @default(0.00) @map("monthly_price") @db.Decimal(12, 2)
  yearlyPrice   Decimal        @default(0.00) @map("yearly_price") @db.Decimal(12, 2)
  maxCompanies  Int            @default(1) @map("max_companies")
  maxUsers      Int            @default(5) @map("max_users")
  features      String?        @db.LongText
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime?      @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime?      @map("updated_at") @db.Timestamp(0)
  subscriptions Subscription[]
  tenants       Tenant[]

  @@map("plans")
}

model Tenant {
  id            BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  planId        BigInt?        @map("plan_id") @db.UnsignedBigInt
  name          String         @db.VarChar(180)
  slug          String?        @unique @db.VarChar(120)
  status        TenantStatus?  @default(trial)
  trialEndsAt   DateTime?      @map("trial_ends_at") @db.Date
  createdAt     DateTime?      @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime?      @map("updated_at") @db.Timestamp(0)
  approvals     Approval[]
  auditLogs     AuditLog[]
  companies     Company[]
  roles         Role[]
  subscriptions Subscription[]
  plan          Plan?          @relation(fields: [planId], references: [id], map: "fk_tenants_plan")
  users         User[]

  @@index([planId], map: "fk_tenants_plan")
  @@map("tenants")
}

model Subscription {
  id           BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  tenantId     BigInt              @map("tenant_id") @db.UnsignedBigInt
  planId       BigInt              @map("plan_id") @db.UnsignedBigInt
  startsAt     DateTime            @map("starts_at") @db.Date
  endsAt       DateTime?           @map("ends_at") @db.Date
  billingCycle BillingCycle?       @default(monthly) @map("billing_cycle")
  amount       Decimal             @default(0.00) @db.Decimal(12, 2)
  status       SubscriptionStatus? @default(active) @map("status")
  createdAt    DateTime?           @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime?           @map("updated_at") @db.Timestamp(0)
  plan         Plan                @relation(fields: [planId], references: [id])
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([planId], map: "subscriptions_plan_id_fkey")
  @@index([tenantId], map: "subscriptions_tenant_id_fkey")
  @@map("subscriptions")
}

model Company {
  id                     BigInt                  @id @default(autoincrement()) @db.UnsignedBigInt
  tenantId               BigInt                  @map("tenant_id") @db.UnsignedBigInt
  name                   String                  @db.VarChar(200)
  legalName              String?                 @map("legal_name") @db.VarChar(220)
  industryType           IndustryType?           @default(mixed) @map("industry_type")
  currencyCode           String?                 @default("EGP") @map("currency_code") @db.Char(3)
  fiscalYearStartMonth   Int?                    @default(1) @map("fiscal_year_start_month") @db.TinyInt
  taxNumber              String?                 @map("tax_number") @db.VarChar(80)
  createdAt              DateTime?               @map("created_at") @db.Timestamp(0)
  updatedAt              DateTime?               @map("updated_at") @db.Timestamp(0)
  accounts               Account[]
  actualImports          ActualImport[]
  bomRecipes             BomRecipe[]
  budgetCycles           BudgetCycle[]
  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  costCenters            CostCenter[]
  customers              Customer[]
  exchangeRates          ExchangeRate[]
  forecastAccuracyLogs   ForecastAccuracyLog[]
  forecastCycles         ForecastCycle[]
  importMappings         ImportMapping[]
  integrationConnections IntegrationConnection[]
  inventorySnapshots     InventorySnapshot[]
  kpiTargets             KpiTarget[]
  materials              Material[]
  notificationRules      NotificationRule[]
  notifications          Notification[]
  productCategories      ProductCategory[]
  productionPlans        ProductionPlan[]
  products               Product[]
  promotions             Promotion[]
  rawMaterialPrices      RawMaterialPrice[]
  scenarios              Scenario[]
  seasonalIndices        SeasonalIndex[]
  sites                  Site[]
  suppliers              Supplier[]
  units                  Unit[]

  @@index([tenantId], map: "idx_companies_tenant")
  @@map("companies")
}

model Role {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  tenantId    BigInt?   @map("tenant_id") @db.UnsignedBigInt
  name        String    @db.VarChar(100)
  permissions String?   @db.LongText
  createdAt   DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime? @map("updated_at") @db.Timestamp(0)
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([tenantId, name], map: "uq_role_name")
  @@index([tenantId], map: "idx_roles_tenant")
  @@map("roles")
}

model User {
  id                     BigInt                  @id @default(autoincrement()) @db.UnsignedBigInt
  tenantId               BigInt                  @map("tenant_id") @db.UnsignedBigInt
  roleId                 BigInt?                 @map("role_id") @db.UnsignedBigInt
  name                   String                  @db.VarChar(160)
  email                  String                  @db.VarChar(190)
  phone                  String?                 @db.VarChar(40)
  passwordHash           String                  @map("password_hash") @db.VarChar(255)
  status                 UserStatus              @default(active)
  lastLoginAt            DateTime?               @map("last_login_at") @db.Timestamp(0)
  createdAt              DateTime?               @map("created_at") @db.Timestamp(0)
  updatedAt              DateTime?               @map("updated_at") @db.Timestamp(0)
  actualImports          ActualImport[]
  approvedApprovals      Approval[]              @relation("approved_approvals")
  requestedApprovals     Approval[]              @relation("requested_approvals")
  auditLogs              AuditLog[]
  budgetApproved         BudgetCycle[]           @relation("budget_approved")
  budgetCreated          BudgetCycle[]           @relation("budget_created")
  createdRates           ExchangeRate[]
  forecastApproved       ForecastCycle[]         @relation("forecast_approved")
  forecastCreated        ForecastCycle[]         @relation("forecast_created")
  importMappings         ImportMapping[]
  integrationConnections IntegrationConnection[]
  kpiTargetsCreated      KpiTarget[]
  rulesCreated           NotificationRule[]
  notifications          Notification[]
  promotions             Promotion[]
  scenariosCreated       Scenario[]
  managedSites           Site[]
  role                   Role?                   @relation(fields: [roleId], references: [id])
  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email], map: "uq_tenant_email")
  @@index([roleId], map: "users_role_id_fkey")
  @@map("users")
}

model Site {
  id                 BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  companyId          BigInt              @map("company_id") @db.UnsignedBigInt
  managerUserId      BigInt?             @map("manager_user_id") @db.UnsignedBigInt
  name               String              @db.VarChar(180)
  type               SiteType
  region             String?             @db.VarChar(120)
  address            String?             @db.VarChar(255)
  status             SiteStatus?         @default(active)
  createdAt          DateTime?           @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime?           @map("updated_at") @db.Timestamp(0)
  actualLines        ActualLine[]
  budgetLines        BudgetLine[]
  costCenters        CostCenter[]
  forecastLines      ForecastLine[]
  headcountPlans     HeadcountPlan[]
  inventorySnapshots InventorySnapshot[]
  kpiTargets         KpiTarget[]
  notificationRules  NotificationRule[]
  productionPlans    ProductionPlan[]
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  manager            User?               @relation(fields: [managerUserId], references: [id])

  @@index([companyId, type], map: "idx_sites_company_type")
  @@index([managerUserId], map: "sites_manager_user_id_fkey")
  @@map("sites")
}

model Unit {
  id        BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  companyId BigInt     @map("company_id") @db.UnsignedBigInt
  name      String     @db.VarChar(80)
  symbol    String     @db.VarChar(20)
  createdAt DateTime?  @map("created_at") @db.Timestamp(0)
  updatedAt DateTime?  @map("updated_at") @db.Timestamp(0)
  materials Material[]
  products  Product[]
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId], map: "units_company_id_fkey")
  @@map("units")
}

model Account {
  id                   BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  companyId            BigInt                @map("company_id") @db.UnsignedBigInt
  parentId             BigInt?               @map("parent_id") @db.UnsignedBigInt
  code                 String                @db.VarChar(50)
  name                 String                @db.VarChar(160)
  type                 AccountType
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime?             @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime?             @map("updated_at") @db.Timestamp(0)
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent               Account?              @relation("account_hierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children             Account[]             @relation("account_hierarchy")
  actualLines          ActualLine[]
  budgetLines          BudgetLine[]
  forecastAccuracyLogs ForecastAccuracyLog[]
  forecastLines        ForecastLine[]
  notificationRules    NotificationRule[]
  seasonalIndices      SeasonalIndex[]

  @@unique([companyId, code], map: "uq_account_code")
  @@index([parentId], map: "accounts_parent_id_fkey")
  @@map("accounts")
}

model CostCenter {
  id             BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  companyId      BigInt          @map("company_id") @db.UnsignedBigInt
  siteId         BigInt?         @map("site_id") @db.UnsignedBigInt
  parentId       BigInt?         @map("parent_id") @db.UnsignedBigInt
  code           String?         @db.VarChar(60)
  name           String          @db.VarChar(160)
  type           CostCenterType? @default(other)
  createdAt      DateTime?       @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime?       @map("updated_at") @db.Timestamp(0)
  actualLines    ActualLine[]
  budgetLines    BudgetLine[]
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent         CostCenter?     @relation("cc_hierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       CostCenter[]    @relation("cc_hierarchy")
  site           Site?           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  forecastLines  ForecastLine[]
  headcountPlans HeadcountPlan[]

  @@index([companyId], map: "idx_cc_company")
  @@index([parentId], map: "cost_centers_parent_id_fkey")
  @@index([siteId], map: "cost_centers_site_id_fkey")
  @@map("cost_centers")
}

model ProductCategory {
  id        BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  companyId BigInt            @map("company_id") @db.UnsignedBigInt
  name      String            @db.VarChar(160)
  parentId  BigInt?           @map("parent_id") @db.UnsignedBigInt
  createdAt DateTime?         @map("created_at") @db.Timestamp(0)
  updatedAt DateTime?         @map("updated_at") @db.Timestamp(0)
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent    ProductCategory?  @relation("pc_hierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  ProductCategory[] @relation("pc_hierarchy")
  products  Product[]

  @@index([companyId], map: "idx_pc_company")
  @@index([parentId], map: "product_categories_parent_id_fkey")
  @@map("product_categories")
}

model Product {
  id                 BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  companyId          BigInt              @map("company_id") @db.UnsignedBigInt
  categoryId         BigInt?             @map("category_id") @db.UnsignedBigInt
  unitId             BigInt?             @map("unit_id") @db.UnsignedBigInt
  sku                String              @db.VarChar(80)
  name               String              @db.VarChar(200)
  productType        ProductType?        @default(finished_good) @map("product_type")
  salePrice          Decimal             @default(0.0000) @map("sale_price") @db.Decimal(14, 4)
  standardCost       Decimal             @default(0.0000) @map("standard_cost") @db.Decimal(14, 4)
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime?           @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime?           @map("updated_at") @db.Timestamp(0)
  actualLines        ActualLine[]
  bomRecipes         BomRecipe[]
  budgetLines        BudgetLine[]
  forecastLines      ForecastLine[]
  inventorySnapshots InventorySnapshot[]
  productionPlans    ProductionPlan[]
  category           ProductCategory?    @relation(fields: [categoryId], references: [id])
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  unit               Unit?               @relation(fields: [unitId], references: [id])
  promotions         Promotion[]

  @@unique([companyId, sku], map: "uq_product_sku")
  @@index([categoryId], map: "products_category_id_fkey")
  @@index([unitId], map: "products_unit_id_fkey")
  @@map("products")
}

model Supplier {
  id        BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  companyId BigInt     @map("company_id") @db.UnsignedBigInt
  name      String     @db.VarChar(200)
  phone     String?    @db.VarChar(50)
  email     String?    @db.VarChar(160)
  createdAt DateTime?  @map("created_at") @db.Timestamp(0)
  updatedAt DateTime?  @map("updated_at") @db.Timestamp(0)
  materials Material[]
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId], map: "suppliers_company_id_fkey")
  @@map("suppliers")
}

model Material {
  id                 BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  companyId          BigInt              @map("company_id") @db.UnsignedBigInt
  supplierId         BigInt?             @map("supplier_id") @db.UnsignedBigInt
  unitId             BigInt?             @map("unit_id") @db.UnsignedBigInt
  code               String              @db.VarChar(80)
  name               String              @db.VarChar(200)
  purchasePrice      Decimal             @default(0.0000) @map("purchase_price") @db.Decimal(14, 4)
  safetyStockQty     Decimal             @default(0.0000) @map("safety_stock_qty") @db.Decimal(14, 4)
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime?           @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime?           @map("updated_at") @db.Timestamp(0)
  actualLines        ActualLine[]
  bomLines           BomLine[]
  budgetLines        BudgetLine[]
  forecastLines      ForecastLine[]
  inventorySnapshots InventorySnapshot[]
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  unit               Unit?               @relation(fields: [unitId], references: [id])
  rawMaterialPrices  RawMaterialPrice[]

  @@unique([companyId, code], map: "uq_material_code")
  @@index([companyId], map: "idx_materials_company")
  @@index([supplierId], map: "materials_supplier_id_fkey")
  @@index([unitId], map: "materials_unit_id_fkey")
  @@map("materials")
}

model Customer {
  id            BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  companyId     BigInt         @map("company_id") @db.UnsignedBigInt
  code          String         @db.VarChar(80)
  name          String         @db.VarChar(200)
  customerType  CustomerType?  @default(retail) @map("customer_type")
  region        String?        @db.VarChar(120)
  phone         String?        @db.VarChar(50)
  email         String?        @db.VarChar(160)
  creditLimit   Decimal        @default(0.00) @map("credit_limit") @db.Decimal(16, 2)
  paymentTerms  Int?           @default(30) @map("payment_terms") @db.TinyInt
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime?      @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime?      @map("updated_at") @db.Timestamp(0)
  actualLines   ActualLine[]
  budgetLines   BudgetLine[]
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  forecastLines ForecastLine[]
  promotions    Promotion[]

  @@unique([companyId, code], map: "uq_customer_code")
  @@index([companyId], map: "idx_customers_company")
  @@map("customers")
}

model ExchangeRate {
  id           BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  companyId    BigInt      @map("company_id") @db.UnsignedBigInt
  fromCurrency String      @map("from_currency") @db.Char(3)
  toCurrency   String      @map("to_currency") @db.Char(3)
  rate         Decimal     @db.Decimal(18, 6)
  rateDate     DateTime    @map("rate_date") @db.Date
  source       RateSource? @default(manual)
  createdBy    BigInt?     @map("created_by") @db.UnsignedBigInt
  createdAt    DateTime?   @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime?   @map("updated_at") @db.Timestamp(0)
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator      User?       @relation(fields: [createdBy], references: [id])

  @@unique([companyId, fromCurrency, toCurrency, rateDate], map: "uq_rate_date")
  @@index([createdBy], map: "exchange_rates_created_by_fkey")
  @@map("exchange_rates")
}

model Promotion {
  id                 BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  companyId          BigInt    @map("company_id") @db.UnsignedBigInt
  name               String    @db.VarChar(160)
  description        String?   @db.Text
  productId          BigInt?   @map("product_id") @db.UnsignedBigInt
  customerId         BigInt?   @map("customer_id") @db.UnsignedBigInt
  discountPct        Decimal?  @map("discount_pct") @db.Decimal(6, 3)
  discountAmt        Decimal?  @map("discount_amount") @db.Decimal(16, 2)
  startDate          DateTime  @map("start_date") @db.Date
  endDate            DateTime? @map("end_date") @db.Date
  budgetAmt          Decimal?  @default(0.00) @map("budget_amount") @db.Decimal(16, 2)
  actualCost         Decimal?  @default(0.00) @map("actual_cost") @db.Decimal(16, 2)
  incrementalRevenue Decimal?  @default(0.00) @map("incremental_revenue") @db.Decimal(16, 2)
  roi                Decimal?  @map("roi") @db.Decimal(7, 2)
  isActive           Boolean   @default(true) @map("is_active")
  createdBy          BigInt?   @map("created_by") @db.UnsignedBigInt
  createdAt          DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime? @map("updated_at") @db.Timestamp(0)
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator            User?     @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  customer           Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product            Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId, isActive], map: "idx_promo_company_active")
  @@index([productId], map: "idx_promo_product")
  @@index([createdBy], map: "promotions_created_by_fkey")
  @@index([customerId], map: "promotions_customer_id_fkey")
  @@map("promotions")
}

model BomRecipe {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  companyId    BigInt    @map("company_id") @db.UnsignedBigInt
  productId    BigInt    @map("product_id") @db.UnsignedBigInt
  version      String?   @default("v1") @db.VarChar(30)
  outputQty    Decimal   @default(1.0000) @map("output_qty") @db.Decimal(14, 4)
  wastagePct   Decimal   @default(0.000) @map("wastage_pct") @db.Decimal(6, 3)
  laborCost    Decimal   @default(0.0000) @map("labor_cost") @db.Decimal(14, 4)
  overheadCost Decimal   @default(0.0000) @map("overhead_cost") @db.Decimal(14, 4)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime? @map("updated_at") @db.Timestamp(0)
  bomLines     BomLine[]
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId], map: "bom_recipes_company_id_fkey")
  @@index([productId], map: "bom_recipes_product_id_fkey")
  @@map("bom_recipes")
}

model BomLine {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  bomId        BigInt    @map("bom_id") @db.UnsignedBigInt
  materialId   BigInt    @map("material_id") @db.UnsignedBigInt
  qtyPerOutput Decimal?  @default(1.000000) @map("qty_per_output") @db.Decimal(14, 6)
  unitCost     Decimal?  @default(0.0000) @map("unit_cost") @db.Decimal(14, 4)
  wastagePct   Decimal?  @default(0.000) @map("wastage_pct") @db.Decimal(6, 3)
  createdAt    DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime? @map("updated_at") @db.Timestamp(0)
  quantity     Decimal   @default(1.0000) @db.Decimal(14, 4)
  bomRecipe    BomRecipe @relation(fields: [bomId], references: [id], onDelete: Cascade)
  material     Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([bomId])
  @@index([materialId])
  @@map("bom_lines")
}

model ForecastCycle {
  id                   BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  companyId            BigInt                @map("company_id") @db.UnsignedBigInt
  scenarioId           BigInt?               @map("scenario_id") @db.UnsignedBigInt
  name                 String                @db.VarChar(160)
  fiscalYear           Int                   @map("fiscal_year")
  basePeriod           DateTime              @map("base_period") @db.Date
  method               ForecastMethod?       @default(manual)
  status               CycleStatus?          @default(draft)
  createdBy            BigInt?               @map("created_by") @db.UnsignedBigInt
  approvedBy           BigInt?               @map("approved_by") @db.UnsignedBigInt
  approvedAt           DateTime?             @map("approved_at") @db.Timestamp(0)
  createdAt            DateTime?             @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime?             @map("updated_at") @db.Timestamp(0)
  forecastAccuracyLogs ForecastAccuracyLog[]
  approver             User?                 @relation("forecast_approved", fields: [approvedBy], references: [id], onDelete: SetNull)
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator              User?                 @relation("forecast_created", fields: [createdBy], references: [id], onDelete: SetNull)
  scenario             Scenario?             @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  forecastLines        ForecastLine[]

  @@index([companyId, fiscalYear], map: "idx_forecast_year")
  @@index([approvedBy], map: "forecast_cycles_approved_by_fkey")
  @@index([createdBy], map: "forecast_cycles_created_by_fkey")
  @@index([scenarioId], map: "forecast_cycles_scenario_id_fkey")
  @@map("forecast_cycles")
}

model ForecastLine {
  id              BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  forecastCycleId BigInt        @map("forecast_cycle_id") @db.UnsignedBigInt
  accountId       BigInt        @map("account_id") @db.UnsignedBigInt
  siteId          BigInt?       @map("site_id") @db.UnsignedBigInt
  costCenterId    BigInt?       @map("cost_center_id") @db.UnsignedBigInt
  productId       BigInt?       @map("product_id") @db.UnsignedBigInt
  materialId      BigInt?       @map("material_id") @db.UnsignedBigInt
  customerId      BigInt?       @map("customer_id") @db.UnsignedBigInt
  periodMonth     Int           @map("period_month") @db.TinyInt
  quantity        Decimal?      @default(0.0000) @db.Decimal(16, 4)
  unitPrice       Decimal?      @default(0.0000) @map("unit_price") @db.Decimal(16, 4)
